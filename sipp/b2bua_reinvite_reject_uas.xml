<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  B2BUA re-INVITE rejected UAS scenario (B-leg side):
  Receive INVITE → 200 → ACK → receive re-INVITE → 488 → ACK
                               → receive BYE → 200

  Tests that the B2BUA ACKs the 488 response (hop-by-hop, same branch)
  per RFC 3261 §17.1.1.3. If Siphon doesn't ACK, the UAS retransmits
  the 488 forever and the test times out.
-->
<scenario name="B2BUA re-INVITE reject UAS">

  <!-- Receive initial INVITE from B2BUA (B-leg) -->
  <recv request="INVITE" crlf="true" />

  <!-- Send 200 OK with SDP -->
  <send retrans="500">
    <![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag01[call_number]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:bob@[local_ip]:[local_port];transport=[transport]>
Content-Type: application/sdp
Content-Length: [len]

v=0
o=bob 53655765 2353687637 IN IP[local_ip_type] [local_ip]
s=-
c=IN IP[media_ip_type] [media_ip]
t=0 0
m=audio [media_port] RTP/AVP 0 8 101
a=rtpmap:0 PCMU/8000
a=rtpmap:8 PCMA/8000
a=rtpmap:101 telephone-event/8000
a=fmtp:101 0-15
a=sendrecv
]]>
  </send>

  <!-- Receive ACK from B2BUA -->
  <recv request="ACK" timeout="5000" />

  <!-- ============================================================ -->
  <!-- Receive re-INVITE from B2BUA (forwarded from A-leg UAC) -->
  <!-- Reject with 488 Not Acceptable Here -->
  <!-- ============================================================ -->
  <recv request="INVITE" crlf="true" />

  <!-- Send 488 Not Acceptable Here -->
  <send retrans="500">
    <![CDATA[
SIP/2.0 488 Not Acceptable Here
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag01[call_number]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

  <!-- ACK from B2BUA for 488 (hop-by-hop, same branch as re-INVITE) -->
  <!-- This is mandatory: if Siphon doesn't ACK, test times out -->
  <recv request="ACK" timeout="5000" />

  <!-- ============================================================ -->
  <!-- Receive BYE — call must survive after rejected re-INVITE -->
  <!-- ============================================================ -->
  <recv request="BYE" />

  <!-- Send 200 OK for BYE -->
  <send>
    <![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

</scenario>
