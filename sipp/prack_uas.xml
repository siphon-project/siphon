<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  RFC 3262 reliable-provisional UAS scenario:
  receive INVITE → send 100 Trying → send 183 Session Progress (RSeq=42,
  Require: 100rel) → recv PRACK → 200 PRACK → 200 INVITE → recv ACK → recv
  BYE → 200 BYE.

  Pair with `prack_uac.xml` on the other side of siphon. Tests that PRACK
  arriving from the UAC at siphon is correctly forwarded back here.
-->
<scenario name="PRACK UAS">

  <recv request="INVITE" crlf="true">
    <!-- Snapshot the INVITE so the final 200 OK can be built AFTER the
         PRACK round-trip (where [last_*] would otherwise refer to the
         PRACK we just answered). The "junk,name" form means
         capture-group-0 (whole match) goes to junk, capture-group-1 to
         the named variable. -->
    <action>
      <ereg regexp="(.*)" search_in="hdr" header="Via:" assign_to="junk,invite_via" />
      <ereg regexp="(.*)" search_in="hdr" header="From:" assign_to="junk,invite_from" />
      <ereg regexp="(.*)" search_in="hdr" header="To:" assign_to="junk,invite_to" />
      <ereg regexp="(.*)" search_in="hdr" header="Call-ID:" assign_to="junk,invite_callid" />
      <ereg regexp="(.*)" search_in="hdr" header="CSeq:" assign_to="junk,invite_cseq" />
    </action>
  </recv>

  <send>
    <![CDATA[
SIP/2.0 100 Trying
[last_Via:]
[last_Record-Route:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

  <!-- Reliable 183 with RSeq=42 -->
  <send retrans="500">
    <![CDATA[
SIP/2.0 183 Session Progress
[last_Via:]
[last_Record-Route:]
[last_From:]
[last_To:];tag=[pid]SIPpTag01[call_number]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:bob@[local_ip]:[local_port];transport=[transport]>
Require: 100rel
RSeq: 42
Content-Type: application/sdp
Content-Length: [len]

v=0
o=bob 53655765 2353687637 IN IP[local_ip_type] [local_ip]
s=-
c=IN IP[media_ip_type] [media_ip]
t=0 0
m=audio [media_port] RTP/AVP 0 8 101
a=rtpmap:0 PCMU/8000
a=rtpmap:8 PCMA/8000
a=rtpmap:101 telephone-event/8000
a=fmtp:101 0-15
]]>
  </send>

  <recv request="PRACK" crlf="true" />

  <send>
    <![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

  <!-- Final 200 for the INVITE — uses the INVITE's stored header values.
       Record-Route is intentionally omitted on this scenario; in a real
       deployment the proxy/B2BUA already inserted it on the inbound path
       and the response just echoes whatever the UAS chooses (typically
       no RR). -->
  <send retrans="500">
    <![CDATA[
SIP/2.0 200 OK
Via:[$invite_via]
From:[$invite_from]
To:[$invite_to];tag=[pid]SIPpTag01[call_number]
Call-ID:[$invite_callid]
CSeq:[$invite_cseq]
Contact: <sip:bob@[local_ip]:[local_port];transport=[transport]>
Content-Length: 0

]]>
  </send>

  <recv request="ACK" crlf="true" />

  <recv request="BYE" />

  <send>
    <![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

</scenario>
