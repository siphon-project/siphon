<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  B2BUA CANCEL UAS scenario (B-leg side):
  Receive INVITE → 180 Ringing → receive CANCEL → 200 (CANCEL) → 487 (INVITE)

  Simulates a slow-ringing endpoint that gets cancelled.

  Kept deliberately free of <ereg>/<action> capture blocks. An earlier version
  captured the INVITE's Via branch / CSeq and re-asserted them on the CANCEL via
  `check_it` regexps (`branch=[$invite_branch]`). That syntax injects a captured
  variable into a match regexp, which this SIPp build rejects with a FATAL error
  (exit 255) at scenario load — so the UAS crashed before it ever bound its
  socket, siphon's B-leg INVITE went unanswered, and the whole test hung.

  The RFC 3261 §9.1 CANCEL→INVITE correlation (same topmost Via branch + CSeq
  sequence number) is instead verified in Rust unit tests
  (`dispatcher::tests::proxy_cancel_via_*` and the B2BUA
  `b2bua_auth_retry_supersedes_failed_leg_for_single_cancel`), which is where
  that invariant actually lives. This scenario just drives the end-to-end flow.

  The matching UAC (b2bua_cancel_uac.xml) sends the INVITE at CSeq 1, so the
  487's CSeq is hardcoded `1 INVITE` (a 487 after a CANCEL must echo the
  INVITE's CSeq, not the CANCEL's — `[last_CSeq:]` would wrongly be `1 CANCEL`).
-->
<scenario name="B2BUA CANCEL UAS">

  <!-- Receive INVITE from B2BUA (B-leg). -->
  <recv request="INVITE" crlf="true" />

  <!-- Send 180 Ringing (keep ringing so the UAC has time to CANCEL). -->
  <send>
    <![CDATA[

SIP/2.0 180 Ringing
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag01[call_number]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:bob@[local_ip]:[local_port];transport=[transport]>
Content-Length: 0

]]>
  </send>

  <!-- Expect the CANCEL from the B2BUA. -->
  <recv request="CANCEL" />

  <!-- Respond 200 OK to the CANCEL. -->
  <send>
    <![CDATA[

SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

  <!-- Respond 487 Request Terminated for the original INVITE. The CSeq must be
       the INVITE's (1 INVITE), not the CANCEL's. -->
  <send>
    <![CDATA[

SIP/2.0 487 Request Terminated
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag01[call_number]
[last_Call-ID:]
CSeq: 1 INVITE
Content-Length: 0

]]>
  </send>

  <!-- Receive ACK for the 487. -->
  <recv request="ACK" optional="true" timeout="5000" />

</scenario>
