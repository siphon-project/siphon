<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  Failure route UAS: simulates a backend that fails twice then succeeds.
  1st INVITE -> 503 Service Unavailable
  2nd INVITE -> 486 Busy Here
  3rd INVITE -> 180 Ringing -> 200 OK -> ACK -> BYE -> 200

  Inspired by Kamailio test/unit/failure_route.xml (GPLv2) — rewritten for SIPhon.
  Used to test sequential forking / failure routing in the proxy.
  Run: sipp -sf failure_route_uas.xml -p 5080
-->
<scenario name="Failure route UAS">

  <!-- 1st INVITE: respond 503 -->
  <recv request="INVITE" />

  <send>
    <![CDATA[
SIP/2.0 503 Service Unavailable
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag01[call_number]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

  <recv request="ACK" optional="true" />

  <pause milliseconds="100" />

  <!-- 2nd INVITE: respond 486 -->
  <recv request="INVITE" />

  <send>
    <![CDATA[
SIP/2.0 486 Busy Here
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag02[call_number]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

  <recv request="ACK" optional="true" />

  <pause milliseconds="100" />

  <!-- 3rd INVITE: success path -->
  <recv request="INVITE" />

  <send>
    <![CDATA[
SIP/2.0 180 Ringing
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag03[call_number]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Content-Length: 0

]]>
  </send>

  <pause milliseconds="500" />

  <send retrans="500">
    <![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag03[call_number]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:[local_ip]:[local_port];transport=[transport]>
Content-Type: application/sdp
Content-Length: [len]

v=0
o=server 53655765 2353687637 IN IP[local_ip_type] [local_ip]
s=-
c=IN IP[media_ip_type] [media_ip]
t=0 0
m=audio [media_port] RTP/AVP 0
a=rtpmap:0 PCMU/8000
]]>
  </send>

  <recv request="ACK" optional="true" />

  <!-- Wait for BYE -->
  <recv request="BYE" />

  <send>
    <![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

  <pause milliseconds="2000" />

</scenario>
