<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  B2BUA topology hiding UAS scenario (B-leg side):
  Validates that the B2BUA properly hides A-leg topology:
  - CSeq is regenerated (should be 1, NOT 99 from A-leg)
  - Max-Forwards is decremented (should be 64, NOT 65)
  - RURI preserves user part (bob@..., not just host)
  - To header host rewritten to dial target (not A-leg advertised)
  - From URI host is siphon's address (172.20.0.50, not UAC's 172.20.0.53)
  - ACK RURI uses Contact from our 200 OK
  - re-INVITE RURI uses our Contact
  - BYE RURI uses our Contact
-->
<scenario name="B2BUA topology hiding UAS">

  <!-- Receive initial INVITE from B2BUA (B-leg) -->
  <recv request="INVITE" crlf="true">
    <action>
      <!-- Validate CSeq is regenerated to 1 (not 99 from A-leg) -->
      <ereg regexp="^1 INVITE" search_in="hdr" header="CSeq:" assign_to="cseq_ok" />
      <ereg regexp="Max-Forwards: 64" search_in="msg" assign_to="mf_ok" />

      <!-- Validate RURI has user part (bob) — not just a bare host -->
      <ereg regexp="INVITE sip:bob@" search_in="msg" assign_to="ruri_user_ok" />

      <!-- Validate To header host is NOT the UAC's IP (172.20.0.53) -->
      <ereg regexp="To:.*172\.20\.0\.53" search_in="msg" assign_to="to_leak" />

      <!-- Validate From host is siphon's (172.20.0.50), not UAC's (172.20.0.53) -->
      <ereg regexp="From:.*172\.20\.0\.53" search_in="msg" assign_to="from_leak" />

      <!-- Save our Contact for ACK RURI validation later -->
      <ereg regexp=".*" search_in="hdr" header="Call-ID:" assign_to="dialog_callid" />
    </action>
  </recv>

  <!-- Send 180 Ringing -->
  <send>
    <![CDATA[
SIP/2.0 180 Ringing
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag01[call_number]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

  <pause milliseconds="200" />

  <!-- Send 200 OK with SDP — Contact is what ACK RURI should use -->
  <send retrans="500">
    <![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag01[call_number]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:bob@[local_ip]:[local_port];transport=[transport]>
Content-Type: application/sdp
Content-Length: [len]

v=0
o=bob 53655765 2353687637 IN IP[local_ip_type] [local_ip]
s=-
c=IN IP[media_ip_type] [media_ip]
t=0 0
m=audio [media_port] RTP/AVP 0 8 101
a=rtpmap:0 PCMU/8000
a=rtpmap:8 PCMA/8000
a=rtpmap:101 telephone-event/8000
a=fmtp:101 0-15
a=sendrecv
]]>
  </send>

  <!-- Receive ACK — RURI must use our Contact (bob@local_ip:local_port) -->
  <recv request="ACK" optional="true" timeout="5000">
    <action>
      <!-- ACK RURI should target our Contact address, not the dial target or A-leg -->
      <ereg regexp="ACK sip:bob@[local_ip]" search_in="msg" assign_to="ack_ruri_ok" />
    </action>
  </recv>

  <!-- Receive re-INVITE — RURI must use our Contact (remote_contact) -->
  <recv request="INVITE" crlf="true">
    <action>
      <!-- re-INVITE RURI should be our Contact (bob@local_ip) -->
      <ereg regexp="INVITE sip:bob@[local_ip]" search_in="msg" assign_to="reinv_ruri_ok" />
      <!-- re-INVITE CSeq should be 2, not 100 from A-leg -->
      <ereg regexp="^2 INVITE" search_in="hdr" header="CSeq:" assign_to="reinv_cseq_ok" />
      <!-- re-INVITE To header must NOT contain UAC's IP (topology leak) -->
      <ereg regexp="To:.*172\.20\.0\.53" search_in="msg" assign_to="reinv_to_leak" />
      <!-- re-INVITE must NOT leak A-leg User-Agent -->
      <ereg regexp="User-Agent:.*SIPp" search_in="msg" assign_to="reinv_ua_leak" />
    </action>
  </recv>

  <!-- 200 OK for re-INVITE -->
  <send retrans="500">
    <![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:];tag=[pid]SIPpTag01[call_number]
[last_Call-ID:]
[last_CSeq:]
Contact: <sip:bob@[local_ip]:[local_port];transport=[transport]>
Content-Type: application/sdp
Content-Length: [len]

v=0
o=bob 53655765 2353687638 IN IP[local_ip_type] [local_ip]
s=-
c=IN IP[media_ip_type] [media_ip]
t=0 0
m=audio [media_port] RTP/AVP 0 8 101
a=rtpmap:0 PCMU/8000
a=rtpmap:8 PCMA/8000
a=rtpmap:101 telephone-event/8000
a=fmtp:101 0-15
a=sendrecv
]]>
  </send>

  <recv request="ACK" optional="true" timeout="5000" />

  <!-- Receive BYE — RURI must use our Contact -->
  <recv request="BYE">
    <action>
      <!-- BYE RURI should be our Contact (bob@local_ip) -->
      <ereg regexp="BYE sip:bob@[local_ip]" search_in="msg" assign_to="bye_ruri_ok" />
      <!-- BYE To header must NOT contain UAC's IP (topology leak) -->
      <ereg regexp="To:.*172\.20\.0\.53" search_in="msg" assign_to="bye_to_leak" />
      <!-- BYE must NOT leak A-leg User-Agent -->
      <ereg regexp="User-Agent:.*SIPp" search_in="msg" assign_to="bye_ua_leak" />
    </action>
  </recv>

  <!-- Send 200 OK for BYE -->
  <send>
    <![CDATA[
SIP/2.0 200 OK
[last_Via:]
[last_From:]
[last_To:]
[last_Call-ID:]
[last_CSeq:]
Content-Length: 0

]]>
  </send>

</scenario>
